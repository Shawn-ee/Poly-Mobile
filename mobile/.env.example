EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3002
EXPO_PUBLIC_API_KEY=
EXPO_PUBLIC_ORDER_MODE=mock
EXPO_PUBLIC_MARKET_DATA_MODE=mock

# Optional. Defaults to EXPO_PUBLIC_API_BASE_URL.
# Use this when Google Cloud is configured for one backend auth domain/callback,
# but the app's market/order API base points somewhere else for local testing.
# This is only a backend auth URL, not a Google Cloud credential or token.
EXPO_PUBLIC_GOOGLE_AUTH_BASE_URL=

# Optional. Real app/dev build default is holiwyn://auth/google.
# For Expo Go/manual S23 OAuth testing, set this to the Expo deep link shown by Expo
# with /--/auth/google appended. The backend accepts exp:/exps: returns only outside production.
# Google Cloud client IDs, secrets, and Google tokens must stay on the backend.
EXPO_PUBLIC_GOOGLE_AUTH_RETURN_URL=holiwyn://auth/google
