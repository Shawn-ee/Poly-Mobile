POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
DEPOSIT_CONFIRMATIONS=20
DEPOSIT_MIN_USD=2
DEPOSIT_WALLET_ENCRYPTION_KEY=replace_with_64_char_hex_secret

# Google OAuth is server-owned. Reuse the same Google Cloud OAuth client
# configured for the Poly/Holiwyn backend; do not put these values in mobile.
# NEXTAUTH_URL controls the callback URL sent to Google in every environment.
# For physical Android local testing, use a backend URL the phone can reach
# and add that /api/auth/google/callback URL to the same Google OAuth client.
GOOGLE_CLIENT_ID=replace_with_google_cloud_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_cloud_oauth_client_secret
NEXTAUTH_URL=http://127.0.0.1:3002
NEXTAUTH_SECRET=replace_with_long_random_secret

# Local Playwright admin login. Keep disabled unless running local e2e.
PLAYWRIGHT_ADMIN_EMAIL=admin.test@poly.local
PLAYWRIGHT_ADMIN_PASSWORD=local-admin-password
ALLOW_DEV_LOGIN=false
