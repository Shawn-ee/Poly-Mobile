generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MarketStatus {
  UPCOMING
  LIVE
  PAUSED
  CLOSED
  RESOLVED
  CANCELED
}

enum MarketKind {
  ORDERBOOK
  POOL
}

enum MarketVisibility {
  PUBLIC
  PRIVATE
}

enum MarketMechanism {
  ORDERBOOK
  POOL
}

enum MarketType {
  BINARY
  MULTI_WINNER
}

enum TradeSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELED
}

enum ComboOrderStatus {
  OPEN
  CANCELED
  SETTLED
  VOIDED
}

enum LedgerReason {
  FAUCET
  DEPOSIT
  WITHDRAW
  BUY
  SELL
  WIN
  FEE
  REFUND
  POOL_BET
  LOCK
  UNLOCK
  FILL
  WITHDRAWAL_REQUEST
  WITHDRAWAL_COMPLETE
  WITHDRAWAL_REJECT
  ORDER_LOCK
  ORDER_RELEASE
  TRADE_FILL
  MARKET_SETTLEMENT
  ADMIN_ADJUSTMENT
}

enum LedgerOperation {
  DEPOSIT
  LOCK
  UNLOCK
  FILL
  WITHDRAWAL_REQUEST
  WITHDRAWAL_COMPLETE
  WITHDRAWAL_REJECT
  FAUCET
  TRADE
  POOL_BET
  OTHER
  WITHDRAWAL
  ORDER_LOCK
  ORDER_RELEASE
  TRADE_FILL
  MARKET_SETTLEMENT
  ADMIN_ADJUSTMENT
}

enum SupportedChain {
  POLYGON
}

enum SupportedToken {
  USDC
}

enum DepositAddressStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum DepositStatus {
  DETECTED
  CONFIRMING
  CREDITED
  FAILED
  IGNORED
}

enum LedgerAsset {
  USDC
}

enum LedgerEntryStatus {
  APPLIED
  FAILED
}

enum AuthProvider {
  google
  wallet
}

enum WalletLinkMethod {
  SIGNATURE
  MANUAL
}

enum LedgerTransactionType {
  DEPOSIT
  WITHDRAW
  BET
  PAYOUT
}

enum LedgerTransactionStatus {
  CREATED
  SUBMITTED
  CONFIRMED
  FAILED
}

enum WithdrawalRequestStatus {
  PENDING
  COMPLETED
  REJECTED
  FAILED
}

enum ApiOrderRequestStatus {
  PROCESSING
  SUCCEEDED
  FAILED
}

enum ApiCredentialStatus {
  ACTIVE
  REVOKED
}

enum CanonicalEventStream {
  MARKET
  ACCOUNT
}

enum MarketMemberRole {
  OWNER
  MEMBER
}

model User {
  id                          String                  @id @default(uuid())
  email                       String?                 @unique
  username                    String                  @unique
  displayName                 String?
  image                       String?
  hasCustomAvatar             Boolean                 @default(false)
  isAdmin                     Boolean                 @default(false)
  lastFaucetAt                DateTime?
  lastTradeAt                 DateTime?
  createdAt                   DateTime                @default(now())
  positions                   Position[]
  trades                      Trade[]
  orders                      Order[]
  comboOrders                 ComboOrder[]
  ledgerEntries               LedgerEntry[]
  poolOwnedMarkets            Market[]                @relation("PoolMarketOwner")
  poolBets                    PoolBet[]
  accounts                    Account[]
  wallets                     Wallet[]
  walletNonces                WalletNonce[]
  ledgerTransactions          LedgerTransaction[]
  depositIntents              DepositIntent[]
  chainDepositEvents          ChainDepositEvent[]
  depositAddresses            UserDepositAddress[]
  deposits                    Deposit[]
  balance                     UserBalance?
  withdrawalRequests          WithdrawalRequest[]
  processedWithdrawalRequests WithdrawalRequest[]     @relation("WithdrawalProcessedByAdmin")
  marketMemberships           MarketMember[]
  apiOrderRequests            ApiOrderRequest[]
  apiCredentials              ApiCredential[]
  apiCredentialUsageLogs      ApiCredentialUsageLog[]
  createdEvents               Event[]                 @relation("EventCreatedBy")
  profilePreferences          UserProfilePreference?
}

model UserProfilePreference {
  userId      String   @id
  preferences Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id              String    @id @default(uuid())
  slug            String?   @unique
  title           String
  description     String?
  category        String?
  sportKey        String?
  leagueKey       String?
  eventType       String?
  homeTeamName    String?
  awayTeamName    String?
  startTime       DateTime?
  status          String?
  liveStatus      String?
  period          String?
  clock           String?
  homeScore       Int?
  awayScore       Int?
  source          String?
  externalEventId String?
  externalSlug    String?
  venue           String?
  image           String?
  imageUrl        String?
  icon            String?
  metadata        Json?
  sourceUpdatedAt DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creator         User?     @relation("EventCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  markets         Market[]

  @@index([category, status])
  @@index([sportKey, leagueKey, status])
  @@index([sportKey, leagueKey, liveStatus])
  @@index([startTime])
  @@index([source, externalEventId])
  @@index([externalSlug])
}

model Market {
  id                      String                   @id @default(uuid())
  slug                    String?                  @unique
  title                   String
  description             String
  categoryLegacy          String?
  categoryId              String?
  category                Category?                @relation(fields: [categoryId], references: [id])
  type                    MarketType               @default(BINARY)
  marketType              String                   @default("generic")
  marketGroupKey          String?
  marketGroupTitle        String?
  displayOrder            Int                      @default(0)
  line                    Decimal?                 @db.Decimal(18, 4)
  unit                    String?
  period                  String?
  participantType         String?
  participantName         String?
  participantId           String?
  propCategory            String?
  kind                    MarketKind               @default(ORDERBOOK)
  status                  MarketStatus             @default(UPCOMING)
  eventId                 String?
  ownerId                 String?
  owner                   User?                    @relation("PoolMarketOwner", fields: [ownerId], references: [id])
  event                   Event?                   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  betCloseTime            DateTime?
  maxParticipants         Int                      @default(100)
  hidePicksUntilClose     Boolean                  @default(false)
  visibility              MarketVisibility         @default(PUBLIC)
  mechanism               MarketMechanism          @default(ORDERBOOK)
  collateralUSDC          Decimal                  @default(0) @db.Decimal(36, 6)
  isCanceled              Boolean                  @default(false)
  isListed                Boolean                  @default(true)
  resolveTime             DateTime?
  createdBy               String?
  resolvedOutcomeId       String?
  externalMarketId        String?
  conditionId             String?
  referenceSource         String?
  externalSlug            String?
  referenceMetadata       Json?
  rules                   Json?
  rulesText               String?
  closeTime               DateTime?
  resolutionTime          DateTime?
  resolutionEvidenceText  String?
  resolutionEvidenceUrl   String?
  voidReason              String?
  settlementStatus        String?
  sourceUpdatedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  outcomes                Outcome[]
  referenceQuoteSnapshots ReferenceQuoteSnapshot[]
  referenceDepthSnapshots ReferenceOrderbookDepthSnapshot[]
  outcomeSnapshots        MarketOutcomeSnapshot[]
  positions               Position[]
  trades                  Trade[]
  fills                   Fill[]
  orders                  Order[]
  comboOrderLegs          ComboOrderLeg[]
  tags                    MarketTag[]
  poolBets                PoolBet[]
  poolStakePresets        PoolStakePreset[]
  members                 MarketMember[]

  @@index([eventId])
  @@index([eventId, marketGroupKey, displayOrder])
  @@index([eventId, status, displayOrder])
  @@index([marketType, status])
  @@index([marketType, propCategory])
  @@index([referenceSource, externalMarketId])
  @@index([conditionId])
  @@index([externalSlug])
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  markets   Market[]
}

model Tag {
  id        String      @id @default(uuid())
  name      String
  slug      String      @unique
  group     String?
  order     Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  markets   MarketTag[]
}

model MarketTag {
  marketId String
  tagId    String
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([marketId, tagId])
  @@index([tagId])
}

model Outcome {
  id                      String                   @id @default(uuid())
  marketId                String
  name                    String
  label                   String?
  code                    String?
  side                    String?
  slug                    String?                  @unique
  isActive                Boolean                  @default(true)
  displayOrder            Int                      @default(0)
  isTradable              Boolean                  @default(true)
  status                  String                   @default("active")
  metadata                Json?
  referenceTokenId        String?
  referenceOutcomeLabel   String?
  referenceMetadata       Json?
  resolvedResult          String?
  createdAt               DateTime                 @default(now())
  market                  Market                   @relation(fields: [marketId], references: [id])
  outcomeSnapshots        MarketOutcomeSnapshot[]
  positions               Position[]
  trades                  Trade[]
  fills                   Fill[]
  orders                  Order[]
  comboOrderLegs          ComboOrderLeg[]
  poolBets                PoolBet[]
  referenceQuoteSnapshots ReferenceQuoteSnapshot[]
  referenceDepthSnapshots ReferenceOrderbookDepthSnapshot[]

  @@unique([marketId, code])
  @@index([marketId, side])
  @@index([marketId, resolvedResult])
  @@index([referenceTokenId])
}

model ReferenceQuoteSnapshot {
  id               String   @id @default(uuid())
  marketId         String
  outcomeId        String
  source           String
  externalSlug     String?
  externalMarketId String?
  conditionId      String?
  tokenId          String?
  outcomeLabel     String?
  outcomePrice     Decimal? @db.Decimal(20, 8)
  bestBid          Decimal? @db.Decimal(20, 8)
  bestAsk          Decimal? @db.Decimal(20, 8)
  spread           Decimal? @db.Decimal(20, 8)
  lastTradePrice   Decimal? @db.Decimal(20, 8)
  volume           Decimal? @db.Decimal(36, 6)
  volume24hr       Decimal? @db.Decimal(36, 6)
  liquidity        Decimal? @db.Decimal(36, 6)
  liquidityClob    Decimal? @db.Decimal(36, 6)
  acceptingOrders  Boolean  @default(false)
  qualityStatus    String?
  mmEligible       Boolean  @default(false)
  reason           String?
  fetchedAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  market           Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome          Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeId, source])
  @@index([marketId, updatedAt])
  @@index([outcomeId, updatedAt])
  @@index([source, updatedAt])
}

model ReferenceOrderbookDepthSnapshot {
  id               String   @id @default(uuid())
  marketId         String
  outcomeId        String
  source           String
  externalSlug     String?
  externalMarketId String?
  conditionId      String?
  tokenId          String?
  side             String
  price            Decimal  @db.Decimal(20, 8)
  size             Decimal  @db.Decimal(36, 6)
  levelIndex       Int
  fetchedAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  market           Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome          Outcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([marketId, outcomeId, source, side, price])
  @@index([marketId, source, fetchedAt])
  @@index([outcomeId, source, fetchedAt])
}

model Position {
  id             String   @id @default(uuid())
  userId         String
  marketId       String
  outcomeId      String
  shares         Decimal  @default(0) @db.Decimal(36, 6)
  avgCost        Decimal  @default(0) @db.Decimal(36, 6)
  reservedShares Decimal  @default(0) @db.Decimal(36, 6)
  realizedPnl    Decimal  @default(0) @db.Decimal(36, 6)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
  market         Market   @relation(fields: [marketId], references: [id])
  outcome        Outcome  @relation(fields: [outcomeId], references: [id])

  @@unique([userId, marketId, outcomeId])
}

model Trade {
  id                String    @id @default(uuid())
  userId            String
  marketId          String
  outcomeId         String
  orderId           String?
  side              TradeSide
  shares            Decimal   @db.Decimal(36, 6)
  cost              Decimal   @db.Decimal(36, 6)
  fee               Decimal   @default(0) @db.Decimal(36, 6)
  selectionSnapshot Json?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id])
  market            Market    @relation(fields: [marketId], references: [id])
  outcome           Outcome   @relation(fields: [outcomeId], references: [id])
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Order {
  id                        String           @id @default(uuid())
  marketId                  String
  userId                    String
  outcomeId                 String
  createdApiCredentialId    String?
  canceledByApiCredentialId String?
  side                      TradeSide
  price                     Decimal          @db.Decimal(20, 8)
  amount                    Decimal          @db.Decimal(36, 6)
  remaining                 Decimal          @db.Decimal(36, 6)
  reservedNotional          Decimal          @default(0) @db.Decimal(36, 6)
  status                    OrderStatus      @default(OPEN)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  market                    Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user                      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcome                   Outcome          @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  apiOrderRequest           ApiOrderRequest?
  trades                    Trade[]
  createdApiCredential      ApiCredential?   @relation("ApiCredentialCreatedOrders", fields: [createdApiCredentialId], references: [id], onDelete: SetNull)
  canceledByApiCredential   ApiCredential?   @relation("ApiCredentialCanceledOrders", fields: [canceledByApiCredentialId], references: [id], onDelete: SetNull)

  @@index([marketId, outcomeId, side, price, createdAt])
  @@index([status, marketId, outcomeId, side, price])
  @@index([userId, marketId, status])
  @@index([createdApiCredentialId, createdAt])
  @@index([canceledByApiCredentialId, updatedAt])
}

model ComboOrder {
  id              String           @id @default(uuid())
  userId          String
  stakeUSDC       Decimal          @db.Decimal(36, 6)
  comboPrice      Decimal          @db.Decimal(20, 8)
  potentialPayout Decimal          @db.Decimal(36, 6)
  status          ComboOrderStatus @default(OPEN)
  idempotencyKey  String
  clientOrderId   String?
  requestFingerprint String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  legs            ComboOrderLeg[]

  @@unique([userId, idempotencyKey])
  @@unique([userId, clientOrderId])
  @@index([userId, status, createdAt])
}

model ComboOrderLeg {
  id           String     @id @default(uuid())
  comboOrderId String
  marketId     String
  outcomeId    String
  price        Decimal    @db.Decimal(20, 8)
  line         String?
  label        String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  comboOrder   ComboOrder @relation(fields: [comboOrderId], references: [id], onDelete: Cascade)
  market       Market     @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome      Outcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([comboOrderId, marketId])
  @@index([comboOrderId, displayOrder])
  @@index([marketId, outcomeId])
}

model ApiOrderRequest {
  id                 String                @id @default(uuid())
  userId             String
  apiCredentialId    String?
  idempotencyKey     String
  clientOrderId      String?
  requestFingerprint String
  requestBody        Json
  submittedNotional  Decimal?              @db.Decimal(36, 6)
  status             ApiOrderRequestStatus @default(PROCESSING)
  orderId            String?               @unique
  responseStatus     Int?
  responseBody       Json?
  errorCode          String?
  errorMessage       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiCredential      ApiCredential?        @relation(fields: [apiCredentialId], references: [id], onDelete: SetNull)
  order              Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey])
  @@unique([userId, clientOrderId])
  @@index([userId, createdAt])
  @@index([apiCredentialId, createdAt])
}

model ApiCredential {
  id                        String                         @id @default(uuid())
  userId                    String
  name                      String
  keyId                     String                         @unique
  secretHash                String
  secretSalt                String
  status                    ApiCredentialStatus            @default(ACTIVE)
  scopes                    String[]
  isDisabled                Boolean                        @default(false)
  readOnly                  Boolean                        @default(false)
  maxOrderSize              Decimal?                       @db.Decimal(36, 6)
  maxOrderNotional          Decimal?                       @db.Decimal(36, 6)
  maxOpenOrders             Int?
  maxDailySubmittedNotional Decimal?                       @db.Decimal(36, 6)
  allowedMarketIds          String[]                       @default([])
  lastUsedAt                DateTime?
  revokedAt                 DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  user                      User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiOrderRequests          ApiOrderRequest[]
  usageLogs                 ApiCredentialUsageLog[]
  createdOrders             Order[]                        @relation("ApiCredentialCreatedOrders")
  canceledOrders            Order[]                        @relation("ApiCredentialCanceledOrders")
  rateLimitBuckets          ApiCredentialRateLimitBucket[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ApiCredentialRateLimitBucket {
  id              String        @id @default(uuid())
  apiCredentialId String
  routeId         String
  windowStart     DateTime
  requestCount    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  apiCredential   ApiCredential @relation(fields: [apiCredentialId], references: [id], onDelete: Cascade)

  @@unique([apiCredentialId, routeId, windowStart])
  @@index([windowStart])
}

model ApiCredentialUsageLog {
  id              String        @id @default(uuid())
  apiCredentialId String
  userId          String
  method          String
  routeId         String
  path            String
  responseStatus  Int
  resultCode      String
  orderId         String?
  createdAt       DateTime      @default(now())
  apiCredential   ApiCredential @relation(fields: [apiCredentialId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([apiCredentialId, createdAt])
  @@index([userId, createdAt])
  @@index([routeId, createdAt])
}

model CanonicalEvent {
  id        BigInt               @id @default(autoincrement())
  stream    CanonicalEventStream
  topicKey  String
  eventType String
  marketId  String?
  outcomeId String?
  userId    String?
  payload   Json
  createdAt DateTime             @default(now())

  @@index([stream, topicKey, id])
  @@index([marketId, id])
  @@index([userId, id])
  @@index([createdAt])
}

model Fill {
  id           String    @id @default(uuid())
  takerOrderId String
  makerOrderId String
  takerUserId  String
  makerUserId  String
  marketId     String
  outcomeId    String
  side         TradeSide
  price        Decimal   @db.Decimal(20, 8)
  size         Decimal   @db.Decimal(36, 6)
  notionalUSDC Decimal   @db.Decimal(36, 6)
  feeUSDC      Decimal   @db.Decimal(36, 6)
  createdAt    DateTime  @default(now())
  market       Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome      Outcome   @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@index([marketId, outcomeId, createdAt])
  @@index([takerOrderId])
  @@index([makerOrderId])
  @@index([takerUserId, createdAt])
  @@index([makerUserId, createdAt])
}

model MarketOutcomeSnapshot {
  id                String   @id @default(uuid())
  marketId          String
  outcomeId         String
  ts                DateTime @default(now())
  price             Decimal  @db.Decimal(36, 6)
  sharesOutstanding Decimal? @db.Decimal(36, 6)
  volumeDelta       Decimal? @db.Decimal(36, 6)

  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([marketId, ts])
  @@index([marketId, outcomeId, ts])
}

model LedgerEntry {
  id                 String            @id @default(uuid())
  userId             String
  asset              LedgerAsset       @default(USDC)
  status             LedgerEntryStatus @default(APPLIED)
  currency           String            @default("GAME_TOKEN")
  amountDelta        Decimal           @db.Decimal(36, 6)
  reason             LedgerReason
  operation          LedgerOperation   @default(OTHER)
  deltaAvailableUSDC Decimal?          @db.Decimal(36, 6)
  deltaLockedUSDC    Decimal?          @db.Decimal(36, 6)
  balanceBefore      Decimal?          @db.Decimal(36, 6)
  balanceAfter       Decimal?          @db.Decimal(36, 6)
  idempotencyKey     String?
  chainId            Int?
  txHash             String?
  logIndex           Int?
  tokenAddress       String?
  referenceType      String?
  referenceId        String?
  createdAt          DateTime          @default(now())
  user               User              @relation(fields: [userId], references: [id])

  @@unique([idempotencyKey])
  @@index([userId, createdAt])
  @@index([operation, createdAt])
}

model UserDepositAddress {
  id                  String               @id @default(uuid())
  userId              String
  chain               SupportedChain
  token               SupportedToken
  address             String               @unique
  encryptedPrivateKey String
  status              DepositAddressStatus @default(ACTIVE)
  lastScannedBlock    BigInt?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits            Deposit[]

  @@unique([userId, chain, token])
  @@index([status, updatedAt])
}

model Deposit {
  id               String             @id @default(uuid())
  userId           String
  depositAddressId String
  chain            SupportedChain
  token            SupportedToken
  txHash           String
  logIndex         Int
  fromAddress      String
  toAddress        String
  amount           Decimal            @db.Decimal(36, 6)
  blockNumber      Int
  confirmations    Int                @default(0)
  detectedAt       DateTime           @default(now())
  creditedAt       DateTime?
  status           DepositStatus      @default(DETECTED)
  rawEventJson     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  depositAddress   UserDepositAddress @relation(fields: [depositAddressId], references: [id], onDelete: Cascade)

  @@unique([chain, txHash, logIndex])
  @@index([userId, createdAt])
  @@index([status, updatedAt])
  @@index([depositAddressId, createdAt])
}

model UserBalance {
  userId        String   @id
  availableUSDC Decimal  @default(0) @db.Decimal(36, 6)
  lockedUSDC    Decimal  @default(0) @db.Decimal(36, 6)
  version       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  createdAt         DateTime     @default(now())
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model WalletNonce {
  address   String   @id
  nonce     String
  mode      String   @default("login")
  userId    String?
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Wallet {
  id         String           @id @default(uuid())
  userId     String
  address    String           @unique
  chainId    Int              @default(1)
  linkMethod WalletLinkMethod @default(SIGNATURE)
  isVerified Boolean          @default(true)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LedgerTransaction {
  id            String                  @id @default(uuid())
  userId        String
  type          LedgerTransactionType
  amount        Decimal                 @db.Decimal(36, 6)
  status        LedgerTransactionStatus @default(CREATED)
  referenceType String?
  referenceId   String?
  txHash        String?
  chainId       Int?
  logIndex      Int?
  tokenAddress  String?
  amountRaw     String?
  metadata      Json?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, chainId, txHash, logIndex])
  @@index([userId, createdAt])
  @@index([status])
}

model DepositIntent {
  id            String                  @id @default(uuid())
  userId        String
  walletAddress String
  chainId       Int
  amount        Decimal                 @db.Decimal(36, 6)
  status        LedgerTransactionStatus @default(CREATED)
  txHash        String?
  createdAt     DateTime                @default(now())
  confirmedAt   DateTime?
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([txHash])
}

model ChainDepositEvent {
  id            String   @id @default(cuid())
  chainId       Int
  txHash        String
  logIndex      Int
  blockNumber   Int
  tokenAddress  String
  fromAddress   String
  toAddress     String
  amountRaw     String
  amountDecimal String?
  userId        String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([chainId, txHash, logIndex])
  @@index([userId, createdAt])
}

model WithdrawalRequest {
  id                 String                  @id
  userId             String
  processedByAdminId String?
  amountUSDC         Decimal                 @db.Decimal(36, 6)
  destinationAddress String?
  status             WithdrawalRequestStatus @default(PENDING)
  adminNotes         String?
  requestedAt        DateTime                @default(now())
  completedAt        DateTime?
  rejectedAt         DateTime?
  completedTxHash    String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  processedByAdmin   User?                   @relation("WithdrawalProcessedByAdmin", fields: [processedByAdminId], references: [id], onDelete: SetNull)

  @@unique([completedTxHash])
  @@index([userId, createdAt])
  @@index([status, requestedAt])
}

model PoolBet {
  id        String   @id @default(uuid())
  userId    String
  marketId  String
  outcomeId String
  amount    Decimal  @db.Decimal(36, 6)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])
  outcome   Outcome  @relation(fields: [outcomeId], references: [id])

  @@unique([userId, marketId])
  @@index([marketId, createdAt])
}

model PoolStakePreset {
  id       String  @id @default(uuid())
  marketId String
  amount   Decimal @db.Decimal(36, 6)
  isActive Boolean @default(true)
  market   Market  @relation(fields: [marketId], references: [id])

  @@unique([marketId, amount])
  @@index([marketId])
}

model MarketMember {
  id        String           @id @default(uuid())
  marketId  String
  userId    String
  role      MarketMemberRole @default(MEMBER)
  createdAt DateTime         @default(now())
  market    Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([marketId, userId])
  @@index([userId, createdAt])
}
