GITHUB_REPO=Shawn-ee/POLY
BASE_BRANCH=dev
DRY_RUN=true
ALLOW_HIGH_RISK=false
MAX_TASKS_PER_CYCLE=1
MAX_FAILED_RUNS_PER_ISSUE=2
MAX_RECURSIVE_FIX_DEPTH=1
REQUIRE_TASK_QUALITY=true
LOOP_INTERVAL_SECONDS=1800
CODEX_COMMAND=codex
TASK_LABELS=codex-ready,agent-task
IGNORE_LABELS=human-review,blocked,high-risk,in-progress
RUNS_DIR=agent-orchestrator/runs
