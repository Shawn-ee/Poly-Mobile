[Unit]
Description=POLY local agent orchestrator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/shawn/projects/poly/Poly
ExecStart=/usr/bin/env bash agent-orchestrator/bin/orchestrator-loop.sh
Restart=always
RestartSec=30

[Install]
WantedBy=default.target
